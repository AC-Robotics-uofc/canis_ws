<?xml version="1.0" encoding="UTF-8"?>
<launch>
    <arg name="shoulder_length" default="0.055"/>
    <arg name="arm_length" default="0.105"/>
    <arg name="forearm_length" default="0.136"/>

    <group>
        <!--node pkg="canis_kinematics_lut" type="leg_inverse_kinematics_lut" name="leg_inverse_kinematics_lut_node"/-->
        <node pkg="canis_kinematics" type="leg_inverse_kinematics" name="leg_inverse_kinematics_node">
   	    <param name="shoulder_length" value="$(arg shoulder_length)"/>
            <param name="arm_length" value="$(arg arm_length)"/>
            <param name="forearm_length" value="$(arg forearm_length)"/>
	</node>
    </group>
</launch>
